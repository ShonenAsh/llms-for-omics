FROM r-polars-bench:base

ARG EXPERIMENT=exp_2a
ARG LEVEL=2a_1_signatures

COPY tasks/ tasks/
COPY tests/ tests/
COPY data/ data/
COPY extract_docs.R .
COPY generate.py .
COPY benchmark.R .
COPY run.sh .
RUN chmod +x run.sh

RUN if [ "${LEVEL}" != "none" ]; then \
        Rscript extract_docs.R "${LEVEL}" && \
        cp docs_conditions/"${LEVEL}"/* tasks/; \
    fi

COPY ${EXPERIMENT}/Prompt.md /workspace/Prompt.md

ENV EXPERIMENT=${EXPERIMENT}
ENV LEVEL=${LEVEL}

ENTRYPOINT ["./run.sh"]
