FROM r-polars-bench:base

ARG EXPERIMENT=exp_2a
ARG LEVEL=2a_1_signatures

COPY tasks/ tasks/
COPY tests/ tests/
COPY data/ data/
COPY extract_docs.R .
COPY generate.py .
COPY benchmark.R .
COPY run.sh .
RUN chmod +x run.sh

RUN Rscript extract_docs.R "${LEVEL}" && \
    cp docs_conditions/"${LEVEL}"/* tasks/

COPY ${EXPERIMENT}/Prompt.md /workspace/Prompt.md

ENV EXPERIMENT=${EXPERIMENT}
ENV LEVEL=${LEVEL}

ENTRYPOINT ["./run.sh"]
