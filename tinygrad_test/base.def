Bootstrap: docker
From: python:3.13-slim

%files
    tasks/ /workspace/tasks/
    tests/ /workspace/tests/
    generate.py /workspace/generate.py
    run.sh /workspace/run.sh

%post
    apt-get update && apt-get install -y --no-install-recommends clang
    rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        "tinygrad>=0.12.0" \
        "numpy>=2.4.4" \
        "pytest>=9.0.2" \
        "litellm>=1.40.0" \
        "instructor>=1.7.0"

    chmod +x /workspace/run.sh

%environment
    export PYTHONPATH=/workspace/submissions:/workspace/tasks
    export MODEL=claude-opus-4-6
    export DEV=CPU

%runscript
    exec /workspace/run.sh "$@"